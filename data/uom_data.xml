<odoo>
    <data noupdate="1">
        <!-- Pharmacy UoM Category -->
        <record id="uom_categ_pharmacy" model="uom.category">
            <field name="name">Pharmacy</field>
        </record>

        <!-- Reference Unit: Unit (smallest) -->
        <record id="product_uom_unit" model="uom.uom">
            <field name="name">Unit</field>
            <field name="category_id" ref="uom_categ_pharmacy"/>
            <field name="uom_type">reference</field>
            <field name="rounding">1.0</field>
        </record>

        <!-- Package Unit (to be adjusted by ratio) -->
        <record id="product_uom_package" model="uom.uom">
            <field name="name">Package</field>
            <field name="category_id" ref="uom_categ_pharmacy"/>
            <field name="uom_type">bigger</field>
            <field name="factor_inv">1.0</field>
            <field name="rounding">0.01</field>
        </record>
    </data>
</odoo>
